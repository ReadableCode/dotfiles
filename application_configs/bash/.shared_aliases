### Command Shortcuts ###

alias ll='ls -AlhF'

# Open all files changed between origin/master and HEAD in VSCode
alias openbranchdiffs='cd $(git rev-parse --show-toplevel) && git fetch -q && git diff --name-only origin/master...HEAD | xargs -I{} code {}'

function gitpullall() {
    local arch os bin
    arch=$(uname -m)
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    bin="$gitDir/dotfiles/go_apps/git_puller/git_puller"

    if [[ "$os" == "darwin" ]]; then
        # macOS: pick arm or x86 binary
        if [[ "$arch" == "arm64" || "$arch" == "aarch64" ]]; then
            bin="${bin}_mac_arm"
        else
            bin="${bin}_mac_x86"
        fi
    elif [[ "$os" == "linux" ]]; then
        # Linux: arm gets a suffix; x86 uses the default binary name
        if [[ "$arch" == "arm64" || "$arch" == "aarch64" ]]; then
            bin="${bin}_arm"
        fi
    fi

    chmod +x "$bin"
    "$bin" -path "$gitDir" -r
}

