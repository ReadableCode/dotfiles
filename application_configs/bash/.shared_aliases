### SSH Shortcuts (loaded from <gitDir>/*_credentials host inventories) ###

# Loads ssh aliases from a hosts.json-style inventory file.
_load_ssh_hosts() {
    local hosts_file="$1"
    [[ -f "$hosts_file" ]] || return 0
    command -v python3 >/dev/null 2>&1 || return 0
    local _alias _user _host _port _ssh_cmd
    while IFS=$'\t' read -r _alias _user _host _port; do
        [[ -z "$_alias" || -z "$_user" ]] && continue
        _ssh_cmd="ssh"
        [[ -n "$_port" ]] && _ssh_cmd="$_ssh_cmd -p $_port"
        _ssh_cmd="$_ssh_cmd ${_user}@${_host}"
        alias "$_alias"="$_ssh_cmd"
    done < <(python3 - "$hosts_file" <<'PYEOF'
import json
import sys

with open(sys.argv[1]) as f:
    inventory = json.load(f)
for host in inventory.get("hosts", []):
    user = host.get("ssh_user") or host.get("user") or ""
    target = host.get("hostname") or host.get("name", "")
    port = host.get("port") or ""
    for alias in host.get("aliases") or []:
        print(f"{alias}\t{user}\t{target}\t{port}")
PYEOF
)
}

# Each sibling repo matching <gitDir>/*_credentials may carry a host
# inventory: <prefix>_hosts.json inside it, falling back to hosts.json.
_load_all_ssh_hosts() {
    [[ -n "$gitDir" ]] || return 0
    # zsh errors out on a non-matching glob; bash leaves it literal and the
    # [[ -d ]] check below skips it.
    [[ -n "$ZSH_VERSION" ]] && setopt localoptions nullglob
    local dir prefix
    for dir in "${gitDir%/}"/*_credentials; do
        [[ -d "$dir" ]] || continue
        prefix="${dir##*/}"
        prefix="${prefix%_credentials}"
        if [[ -f "$dir/${prefix}_hosts.json" ]]; then
            _load_ssh_hosts "$dir/${prefix}_hosts.json"
        elif [[ -f "$dir/hosts.json" ]]; then
            _load_ssh_hosts "$dir/hosts.json"
        fi
    done
}

_load_all_ssh_hosts
