# Open the files this branch changed (vs the merge-base with the default branch) in VSCode.
# Skips deleted/renamed-away paths and never includes changes that only happened upstream.
function openbranchdiffs() {
    local root base f
    local -a files=()
    root=$(git rev-parse --show-toplevel 2>/dev/null) || { echo "Not a git repository." >&2; return 1; }
    cd "$root" || return 1
    git fetch -q
    base=$(git symbolic-ref --short refs/remotes/origin/HEAD 2>/dev/null || echo origin/master)
    # base...HEAD diffs from the merge-base, so only this branch's own commits count;
    # --diff-filter=d drops files deleted on this branch
    while IFS= read -r f; do
        [ -e "$f" ] && files+=("$f")
    done < <(git diff --name-only --diff-filter=d "$base"...HEAD)
    if [ ${#files[@]} -eq 0 ]; then
        echo "No files changed on this branch relative to $base."
        return 0
    fi
    code "${files[@]}"
}

function gitpullall() {
    local arch os bin
    arch=$(uname -m)
    os=$(uname -s | tr '[:upper:]' '[:lower:]')
    bin="$gitDir/dotfiles/go_apps/git_puller/git_puller"

    if [[ "$os" == "darwin" ]]; then
        # macOS: pick arm or x86 binary
        if [[ "$arch" == "arm64" || "$arch" == "aarch64" ]]; then
            bin="${bin}_mac_arm"
        else
            bin="${bin}_mac_x86"
        fi
    elif [[ "$os" == "linux" ]]; then
        # Linux: arm gets a suffix; x86 uses the default binary name
        if [[ "$arch" == "arm64" || "$arch" == "aarch64" ]]; then
            bin="${bin}_arm"
        fi
    fi

    chmod +x "$bin"
    "$bin" -path "$gitDir" -r
    echo ""
	echo ""

    if command -v uv >/dev/null 2>&1; then
        # Deploy after the pulls: idempotent, and re-links the hard links
        # the pulls just orphaned (no-symlink machines like work laptops).
        printf '\033[1;36m%s\033[0m\n' '──────────────  Deploying configs  ──────────────'
        (cd "$gitDir/dotfiles" && uv run python src/deploy_configs.py)
    else
        echo "uv not found, skipping config deploy."
    fi
}

