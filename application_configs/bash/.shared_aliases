alias ll='ls -AlhF'

# Open all files changed between origin/master and HEAD in VSCode
alias openbranchdiffs='cd $(git rev-parse --show-toplevel) && git fetch -q && git diff --name-only origin/master...HEAD | xargs -I{} code {}'

function gitpullall() {
    [ -z "$gitDir" ] && { echo "gitDir is not set" >&2; return 1; }
    # git_puller lives in the go-tools repo (github.com/ReadableCode/go-tools).
    # Install it on PATH from a release download or: go install github.com/ReadableCode/go-tools/git_puller@latest
    if ! command -v git_puller >/dev/null 2>&1; then
        echo "git_puller not found on PATH. Get it from the go-tools repo releases" >&2
        echo "or run: go install github.com/ReadableCode/go-tools/git_puller@latest" >&2
        return 1
    fi
    git_puller -path "$gitDir" -r
}

