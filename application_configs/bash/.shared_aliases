### Python ###

alias venvactivate='source ./.venv/bin/activate'

alias venvdeactivate='deactivate'

function run_python_script() {
    # Check if a file path argument is provided
    if [ -z "$1" ]; then
        echo "Usage: run_python_script <python_script_path> [args...]" >&2
        return 1
    fi

    local script_path="$1"
    shift  # remove script path, leaving any extra args to pass through

    local script_dir
    script_dir=$(dirname "$script_path")

    # Look for a .venv one level up from the script (standard project layout)
    local venv_dir
    venv_dir="$(dirname "$script_dir")/.venv"

    echo "Running Python script: $script_path"
    echo "Changing to script directory: $script_dir"
    cd "$script_dir" || return 1

    # Use the project venv if it exists, otherwise fall back to system Python
    if [ -d "$venv_dir" ]; then
        echo "Project .venv detected at: $venv_dir"
        source "$venv_dir/bin/activate"
        python3 "$script_path" "$@"
        deactivate
    else
        echo "No project .venv found in parent directory. Running the script with system Python."
        python3 "$script_path" "$@"
    fi
}

