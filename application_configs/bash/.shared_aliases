unalias venvactivate 2>/dev/null

venvactivate() {
    local dir="$PWD"
    while [ "$dir" != "/" ]; do
        if [ -d "$dir/.venv" ]; then
            if [ -f "$dir/.venv/bin/activate" ]; then
                source "$dir/.venv/bin/activate"
                return
            elif [ -f "$dir/.venv/Scripts/activate" ]; then
                source "$dir/.venv/Scripts/activate"
                return
            fi
        fi
        dir=$(dirname "$dir")
    done
    echo "venvactivate: no .venv found in $PWD or any parent directory" >&2
    return 1
}

alias venvdeactivate='deactivate'

function run_python_script() {
    if [ -z "$1" ]; then
        echo "Usage: run_python_script <python_script_path> [args...]" >&2
        return 1
    fi
    (
        script_path=$(realpath "$1")
        shift
        script_dir=$(dirname "$script_path")

        find_venv() {
            local dir="$1"
            while [ "$dir" != "/" ]; do
                [ -d "$dir/.venv" ] && echo "$dir/.venv" && return
                dir=$(dirname "$dir")
            done
        }

        echo "Running Python script: $script_path"
        echo "Changing to script directory: $script_dir"
        cd "$script_dir" || exit 1

        venv_dir=$(find_venv "$script_dir")

        if [ -n "$venv_dir" ]; then
            echo "Project .venv detected at: $venv_dir"
            source "$venv_dir/bin/activate"
        else
            echo "No project .venv found. Running with system Python."
        fi

        python3 "$script_path" "$@"
    )
}

