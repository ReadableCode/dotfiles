// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ssh_connections": [
    {
      "host": "192.168.86.126",
      "args": [],
      "projects": [
        {
          "paths": ["~/GitHub/dotfiles/", "~/GitHub/fourteen_foods/"],
        },
      ],
    },
  ],
  "terminal": {
    "option_as_meta": true,
  },
  "project_panel": {
    "dock": "left",
  },
  "base_keymap": "VSCode",
  "sticky_scroll": {
    "enabled": true,
  },
  "minimap": {
    "thumb": "always",
  },
  "cursor_blink": true,
  "autosave": "on_focus_change",
  "file_types": {
    "markdown": ["*.md"],
    "yaml": ["*.yaml"],
    "helm": ["templates/*.yaml"],
  },
  "colorize_brackets": true,
  "auto_indent_on_paste": true,
  "show_whitespaces": "all",
  "show_edit_predictions": true,
  "semantic_tokens": "full",
  "line_ending": "prefer_lf",
  "remove_trailing_whitespace_on_save": false,
  "soft_wrap": "none",
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
  },
  "ui_font_size": 16,
  "buffer_font_size": 15,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark",
  },
}
